  url       = "postgresql://neondb_owner:npg_C1HqYDR4ObGf@ep-autumn-mud-aepfendo.c-2.us-east-2.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
  directUrl = "postgresql://neondb_owner:npg_C1HqYDR4ObGf@ep-autumn-mud-aepfendo.c-2.us-east-2.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
}

model User {
  id          String   @id @default(uuid())
  firstName   String
  lastName    String
  email       String   @unique
  password    String
  dateAdded   DateTime @default(now())
  dateUpdated DateTime @updatedAt @db.Date
  company     Company? @relation(fields: [companyId], references: [id])
  companyId   String?
  isAdmin     Boolean  @default(false)
}

model Company {
  id            String   @id @default(uuid())
  name          String   @unique
  phoneNumber   String   @unique
  streetAddress String
  city          String
  state         String
  zip           Int
  dateAdded     DateTime @default(now())
  dateUpdated   DateTime @updatedAt
  employees     User[]
}

model Token {
  id           Int      @id @default(autoincrement())
  accessToken  String? // access token from QuickBooks
  refreshToken String // refresh token
  realmId      String? // qb company ID
  dateAdded    DateTime @default(now())
  dateUpdated  DateTime @updatedAt
}
